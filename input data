from dataclasses import dataclass

@dataclass
class Tool:
    diameter: float
    length: float
    type: str  # "ball", "flat", "bull"
    material: str

@dataclass
class Material:
    name: str
    hardness: float

@dataclass
class Stock:
    size_x: float
    size_y: float
    size_z: float

@dataclass
class PartFeatures:
    bounding_box: tuple
    surface_area: float
    curvature: float
    pockets: int
    holes: int

@dataclass
class MachiningContext:
    tool: Tool
    material: Material
    stock: Stock
    features: PartFeatures
