import numpy as np

def generate_raster_toolpath(bounds, step_over, z_height):
    x_min, y_min, x_max, y_max = bounds

    toolpath = []
    direction = 1

    y = y_min
    while y <= y_max:
        if direction == 1:
            toolpath.append([(x_min, y, z_height), (x_max, y, z_height)])
        else:
            toolpath.append([(x_max, y, z_height), (x_min, y, z_height)])

        direction *= -1
        y += step_over

    return toolpath
